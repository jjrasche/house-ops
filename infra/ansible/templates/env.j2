############
# Secrets
############

POSTGRES_PASSWORD={{ postgres_password }}
JWT_SECRET={{ jwt_secret }}
ANON_KEY={{ anon_key }}
SERVICE_ROLE_KEY={{ service_role_key }}
DASHBOARD_USERNAME={{ dashboard_username }}
DASHBOARD_PASSWORD={{ dashboard_password }}

############
# Database
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# API
############

SITE_URL=https://{{ domain }}
SUPABASE_PUBLIC_URL=https://{{ domain }}
API_EXTERNAL_URL=https://{{ domain }}

############
# Auth / GoTrue
############

GOTRUE_SITE_URL=https://{{ domain }}
GOTRUE_URI_ALLOW_LIST=
GOTRUE_DISABLE_SIGNUP=true
GOTRUE_JWT_ADMIN_ROLES=service_role
GOTRUE_JWT_AUD=authenticated
GOTRUE_JWT_DEFAULT_GROUP_NAME=authenticated
GOTRUE_JWT_EXP=3600
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_EXTERNAL_ANONYMOUS_USERS_ENABLED=false

############
# Studio
############

STUDIO_DEFAULT_ORGANIZATION=HouseOps
STUDIO_DEFAULT_PROJECT=HouseOps
STUDIO_PORT=3000
SUPABASE_STUDIO_PORT=3000

############
# Kong
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############
# Realtime
############

REALTIME_POLL_INTERVAL=100
REALTIME_POLL_MAX_RECORD_BYTES=1048576

############
# Storage
############

STORAGE_BACKEND=file
STORAGE_FILE_BACKEND_PATH=/var/lib/storage
FILE_SIZE_LIMIT=52428800
GLOBAL_S3_BUCKET=stub

############
# SMTP (disabled - manual user creation only)
############

SMTP_ADMIN_EMAIL=admin@{{ domain }}
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake
SMTP_PASS=fake
SMTP_SENDER_NAME=HouseOps

############
# Analytics (disabled)
############

LOGFLARE_LOGGER_BACKEND_API_KEY=not-used
LOGFLARE_API_KEY=not-used

############
# Functions
############

FUNCTIONS_VERIFY_JWT=true
GROQ_API_KEY={{ groq_api_key }}
